# auto 会优先使用真实硬件，检测不到时回退到明确标记的模拟后端。
STARFINDING_CAMERA_BACKEND=auto
STARFINDING_PLATE_SOLVER_BACKEND=auto
STARFINDING_ALLOW_MOCK_FALLBACK=true
STARFINDING_DATA_DIR=/var/lib/starfinding-gateway
STARFINDING_GPHOTO2=gphoto2
STARFINDING_SOLVE_FIELD=solve-field
STARFINDING_FFMPEG=ffmpeg
STARFINDING_COMMAND_TIMEOUT=45
STARFINDING_CAPTURE_TIMEOUT=360
STARFINDING_MAX_UPLOAD_BYTES=83886080
# 相机访问必须串行。只有确认没有并发触发 R7 后才可增加此值。
STARFINDING_WORKERS=1
