# 服务运行参数
STARFINDING_DATA_DIR=/data
ENHANCEMENT_BACKEND=auto
MAX_UPLOAD_MB=40

# ModelArts 在线服务。auto 模式下配置完整才调用；调用失败会自动回退本地增强。
MODELARTS_ENABLED=false
MODELARTS_ENDPOINT=https://your-modelarts-endpoint.example.com/v1/infers
MODELARTS_TOKEN=replace-with-short-lived-token
MODELARTS_AUTH_HEADER=X-Auth-Token
MODELARTS_TIMEOUT_SECONDS=20

# OBS 留作原图/结果归档适配器使用。当前版本始终先在本地持久化，不依赖 OBS 成功。
OBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com
OBS_ACCESS_KEY_ID=replace-me
OBS_SECRET_ACCESS_KEY=replace-me
OBS_BUCKET=starfinding-artifacts
